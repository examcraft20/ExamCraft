{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@examcraft/ui": ["packages/ui/src"],
      "@examcraft/types": ["packages/types/src"],
      "@examcraft/sdk": ["packages/sdk/src"]
    }
  }
}

