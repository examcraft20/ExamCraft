# Production Environment Variables for ExamCraft
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to version control!

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL=https://examcraft.vercel.app
NEXT_PUBLIC_API_URL=https://examcraft-api.railway.app/api

# ============================================
# Supabase Configuration (PRODUCTION)
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# Database connection string (for backend migrations)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ============================================
# API Configuration
# ============================================
API_PORT=4000
NODE_ENV=production

# ============================================
# Demo Mode (MUST BE FALSE IN PRODUCTION)
# ============================================
NEXT_PUBLIC_DEMO_MODE=false

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRATION=7d

# ============================================
# Email Configuration (for notifications)
# ============================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your_resend_api_key
EMAIL_FROM=noreply@examcraft.com

# ============================================
# Storage Configuration
# ============================================
SUPABASE_STORAGE_BUCKET=papers

# ============================================
# Monitoring & Error Tracking
# ============================================
SENTRY_DSN=https://YOUR_SENTRY_DSN@oXXXXX.ingest.sentry.io/XXXXX

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=https://examcraft.vercel.app

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# AI / Gemini Configuration (Blocker #3)
# ============================================
# Get free API key from: https://aistudio.google.com/app/apikey
# Add to Railway: Settings → Variables → GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here
