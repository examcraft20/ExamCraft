{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile"
  },
  "deploy": {
    "startCommand": "pnpm --filter=api start:prod",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "numReplicas": 1
  }
}
